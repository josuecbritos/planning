# Copia este archivo a `.env` y completa con los datos de tu proyecto Supabase.
# Si estas variables NO estan presentes, la app corre en modo "Local"
# (datos en memoria + localStorage), util para demos sin backend.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
